#!/usr/bin/env bash
# ================================================================
# bun_buildpack — supply
#
# Provides the Bun runtime.
# Does NOT run bun install or any package manager command.
# ================================================================
set -euo pipefail

BUILD_DIR="$1"
CACHE_DIR="$2"
DEPS_DIR="$3"
DEPS_IDX="$4"

BUILDPACK_DIR=$(cd "$(dirname "${BASH_SOURCE[0]}")/.." && pwd)
source "${BUILDPACK_DIR}/lib/utils.sh"
require_python3

# ── Determine version ────────────────────────────────────────────

REQUESTED_BUN=$(read_package_field "${BUILD_DIR}/package.json" "engines.bun")

# Call resolve in current shell (not subshell) so RESOLVE_ERROR survives.
# Redirect stdout to /dev/null; use RESOLVED_VERSION global instead.
if ! resolve_bun_version "${REQUESTED_BUN}" >/dev/null; then
  log_error "$RESOLVE_ERROR"
  exit 1
fi
BUN_VERSION="$RESOLVED_VERSION"

# Allow env var override (highest priority)
BUN_VERSION="${BUN_OVERRIDE_VERSION:-$BUN_VERSION}"

log_info "Supply phase starting"
log_detail "Bun version: v${BUN_VERSION} (requested: '${REQUESTED_BUN:-not set}')"

# ── Download and cache Bun binary ────────────────────────────────

BUN_ZIP="bun-v${BUN_VERSION}-linux-x64.zip"
BUN_CACHE="${CACHE_DIR}/${BUN_ZIP}"
BUN_INSTALL_DIR="${DEPS_DIR}/${DEPS_IDX}/bun"

if [ -f "$BUN_CACHE" ]; then
  log_info "Using cached Bun v${BUN_VERSION}"
else
  # Clean old cached versions (narrow pattern to avoid colliding with other buildpacks)
  rm -f "${CACHE_DIR}"/bun-v[0-9]*-linux-x64.zip

  BUN_URL="${BUN_DOWNLOAD_URL:-https://github.com/oven-sh/bun/releases/download/bun-v${BUN_VERSION}/bun-linux-x64.zip}"
  log_info "Downloading Bun v${BUN_VERSION}"
  log_detail "${BUN_URL}"

  HTTP_CODE=$(curl -sL -w "%{http_code}" -o "$BUN_CACHE" "$BUN_URL")
  if [ "$HTTP_CODE" != "200" ]; then
    log_error "Download failed with HTTP ${HTTP_CODE}"
    log_error "Check that Bun v${BUN_VERSION} exists at the download URL"
    rm -f "$BUN_CACHE"
    exit 1
  fi
fi

# ── SHA256 Checksum Verification (fail-closed) ──────────────────

if [ "${BUN_SKIP_CHECKSUM:-}" = "true" ]; then
  log_warn "BUN_SKIP_CHECKSUM=true — skipping checksum verification"
else
  ACTUAL_SHA=$(sha256sum "$BUN_CACHE" | awk '{print $1}')

  if [ -n "${BUN_DOWNLOAD_SHA256:-}" ]; then
    # Source 1: direct SHA256 from env var
    EXPECTED_SHA="$BUN_DOWNLOAD_SHA256"
    log_detail "Verifying SHA256 (from BUN_DOWNLOAD_SHA256)"
  else
    # Source 2 or 3: fetch SHASUMS256.txt
    SHASUMS_URL="${BUN_SHASUMS_URL:-https://github.com/oven-sh/bun/releases/download/bun-v${BUN_VERSION}/SHASUMS256.txt}"
    log_detail "Fetching checksums from ${SHASUMS_URL}"
    EXPECTED_SHA=$(curl -sL "$SHASUMS_URL" | grep "bun-linux-x64.zip" | awk '{print $1}' || true)

    if [ -z "$EXPECTED_SHA" ]; then
      log_error "Could not fetch or parse SHASUMS256.txt — cannot verify integrity"
      log_error "Set BUN_SKIP_CHECKSUM=true to bypass (not recommended)"
      rm -f "$BUN_CACHE"
      exit 1
    fi
  fi

  if [ "$ACTUAL_SHA" != "$EXPECTED_SHA" ]; then
    log_error "SHA256 checksum mismatch for Bun v${BUN_VERSION}"
    log_error "Expected: ${EXPECTED_SHA}"
    log_error "Actual:   ${ACTUAL_SHA}"
    rm -f "$BUN_CACHE"
    exit 1
  fi
  log_detail "SHA256 checksum verified"
fi

# ── Extract Bun binary ──────────────────────────────────────────

BUN_TMP=$(mktemp -d)
unzip -q "$BUN_CACHE" -d "$BUN_TMP"

mkdir -p "${BUN_INSTALL_DIR}/bin"
mv "${BUN_TMP}/bun-linux-x64/bun" "${BUN_INSTALL_DIR}/bin/bun"
chmod +x "${BUN_INSTALL_DIR}/bin/bun"
rm -rf "$BUN_TMP"

# ── Set up PATH via profile.d ───────────────────────────────────
#
# This script runs at container start.  Two subtleties:
#   1. DEPS_DIR at staging may differ from the runtime path
#      (/home/vcap/deps), so we must NOT hardcode the staging value.
#   2. SAP BTP CF may not source $DEPS_DIR/$IDX/profile.d/ for a
#      buildpack that acts as both supply and finalize, so we also
#      write to $BUILD_DIR/.profile.d/ (always sourced by the launcher).
#
# DEPS_IDX is a buildpack-specific index not available at runtime,
# so we replace it with a __DEPS_IDX__ placeholder via sed.

PROFILE_DIR="${DEPS_DIR}/${DEPS_IDX}/profile.d"
mkdir -p "$PROFILE_DIR"

cat <<'PROFILE' > "${PROFILE_DIR}/000_bun.sh"
# Auto-generated by bun_buildpack
DEPS_DIR_RUNTIME="${DEPS_DIR:-/home/vcap/deps}"
export BUN_INSTALL="${DEPS_DIR_RUNTIME}/__DEPS_IDX__/bun"
export PATH="${BUN_INSTALL}/bin:${DEPS_DIR_RUNTIME}/__DEPS_IDX__/bin:${PATH}"
export NODE_ENV="${NODE_ENV:-production}"
PROFILE

# Replace DEPS_IDX placeholder (not available as env var at runtime)
sed -i "s|__DEPS_IDX__|${DEPS_IDX}|g" "${PROFILE_DIR}/000_bun.sh"

# Also install into $BUILD_DIR/.profile.d/ — guaranteed to be sourced
# by the CF launcher regardless of buildpack type
mkdir -p "${BUILD_DIR}/.profile.d"
cp "${PROFILE_DIR}/000_bun.sh" "${BUILD_DIR}/.profile.d/000_bun.sh"

# ── Create symlinks for immediate use in finalize phase ─────────

mkdir -p "${DEPS_DIR}/${DEPS_IDX}/bin"
ln -sf "${BUN_INSTALL_DIR}/bin/bun" "${DEPS_DIR}/${DEPS_IDX}/bin/bun"

# Make available to subsequent buildpack phases
export PATH="${BUN_INSTALL_DIR}/bin:${DEPS_DIR}/${DEPS_IDX}/bin:${PATH}"

log_info "Supply phase complete"
log_detail "bun v${BUN_VERSION}"
